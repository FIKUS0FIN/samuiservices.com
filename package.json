{
  "name": "samuiservices",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && prisma db push --accept-data-loss && next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "seed:businesses": "tsx scripts/seed-businesses.ts",
    "test": "vitest run",
    "pretest:e2e": "DATABASE_URL=file:./test.db npx prisma db push --force-reset",
    "test:e2e": "NEXT_PUBLIC_TEST_MODE=true DATABASE_URL=file:./test.db next build && NEXT_PUBLIC_TEST_MODE=true DATABASE_URL=file:./test.db playwright test",
    "test:e2e:remote": "ADMIN_TEST_PASSWORD=${ADMIN_TEST_PASSWORD:-secret} BASE_URL=${BASE_URL:-https://samuiservices.com} playwright test",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1076.0",
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "gray-matter": "^4.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260625.1",
    "@faker-js/faker": "^10.5.0",
    "@opennextjs/cloudflare": "^1.20.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "wrangler": "^4.104.0"
  }
}
